# ================================================================
# POSManual — DevSys Honduras
# Variables de entorno — PRODUCCIÓN (Railway)
# ================================================================
# Copiá este archivo a .env y completá cada valor.
# En Railway, estas variables se configuran en:
#   Dashboard → Tu proyecto → Variables
# ================================================================

# ── Base de datos (Railway PostgreSQL) ──────────────────────────
# Railway genera esta URL automáticamente al agregar el plugin PostgreSQL.
# Formato: postgresql://usuario:password@host:5432/nombre_db
DATABASE_URL=postgresql://postgres:TU_PASSWORD@roundhouse.proxy.rlwy.net:PORT/railway

# ── Seguridad JWT ────────────────────────────────────────────────
# Generá una clave aleatoria segura de al menos 64 caracteres:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_CLAVE_ALEATORIA_DE_64_CHARS_MINIMO
JWT_EXPIRES_IN=8h

# ── Servidor ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS: URL del frontend en Railway ───────────────────────────
# Si el frontend y backend están en el mismo servicio (monorepo),
# dejá esto vacío o igual al dominio de Railway.
# Si son servicios separados: CLIENT_URL=https://posmanual-client.up.railway.app
CLIENT_URL=https://posmanual.up.railway.app

# ── Datos fiscales SAR Honduras ──────────────────────────────────
RTN_EMPRESA=05019009204111
NOMBRE_EMPRESA=INVERSIONES BUENOS AIRES S.A.
DIRECCION_EMPRESA=Bo. Buenos Aires BLVD del norte, San Pedro Sula, Honduras
TELEFONO_EMPRESA=+504 2527-8133/8119
EMAIL_EMPRESA=gerenciatexacoba@gmail.com

# CAI activo — actualizar cuando venza (09/10/2026)
CAI_ACTIVO=40BC19-7CF1EF-C2FBE0-63BE03-0909B8-D4
CAI_FECHA_LIMITE=09/10/2026
CAI_RANGO_INICIO=000-009-01-03816501
CAI_RANGO_FIN=000-009-01-04066500

# ── Puppeteer / Chromium (generación de PDF) ────────────────────
# Railway incluye Chromium en el buildpack, no necesita ruta manual.
# Solo necesitás esto en VPS propio:
# CHROMIUM_PATH=/usr/bin/chromium-browser

# ── Email (opcional — para envío de facturas) ───────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=app_password_de_google
# SMTP_FROM="POSManual <pos@buenosaireshonduras.hn>"

# ── Frontend (Vite) ──────────────────────────────────────────────
# Estas variables son para el cliente React (prefijo VITE_ obligatorio)
VITE_API_URL=https://posmanual.up.railway.app/api/v1
